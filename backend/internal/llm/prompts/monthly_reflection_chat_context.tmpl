{{/* Dynamic context block for the COMBINED weekly+monthly reflection
   chat. Concatenated after the static monthly persona prompt. Variables:

     .DisplayName             — user-facing name (may be empty)
     .WeekStart, .WeekEnd     — YYYY-MM-DD bounds of the hosting week
     .MonthLabel              — e.g. "June 2026"
     .MonthStart, .MonthEnd   — YYYY-MM-DD bounds of the month being closed
     .Letter                  — the weekly letter (Charged/Drained/Grateful/Insights/ClosingQuestion)
     .MonthlyLetter           — the monthly letter (Headline/Arc/Recurring/GoalsRetro/ClosingQuestion)
     .TopDrainers/.TopChargers — []TagSummary top 3 for the week
     .MidFlightGoals          — []GoalView (end_date > WeekEnd)
     .EndingGoals             — []GoalView (end_date <= WeekEnd) — REQUIRE decision
     .GoalLedger              — []GoalLedgerView the month's goal history (read-only)
     .PrevWeekSurprise        — last week's distilled continuity note
     .LastMonthIntention      — intention set at LAST month's reflection (settle conversationally)
     .LastMonthDirection      — direction note from last month's reflection
     .IntentionText           — already-accepted intention for THIS closing month (resumed session)
     .Ratings                 — []RatingView{Label, Score, Delta} this month's life check-in
     .Memories                — []MemoryGroup durable user facts
     .Phase                   — current ChatPhase enum value
*/ -}}

