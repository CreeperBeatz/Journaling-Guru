# --- Server ---
APP_ENV=dev                       # dev | prod
LOG_LEVEL=debug                   # debug | info | warn | error
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:5173

# --- Database ---
DATABASE_URL=postgres://journai:journai@localhost:5432/journai?sslmode=disable

# --- Sessions / cookies ---
SESSION_COOKIE_NAME=session
SESSION_TTL_HOURS=720             # 30 days
COOKIE_SECURE=false               # true in prod (HTTPS)

# --- Magic link ---
MAGIC_LINK_TTL_MINUTES=15
MAGIC_LINK_PER_EMAIL_15M=3
MAGIC_LINK_PER_EMAIL_DAY=10
MAGIC_LINK_PER_IP_HOUR=20

# --- Mail ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="JournAI <hello@journai.local>"

# --- LLM (summaries + voice transcript mapping) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# --- OpenAI Realtime (voice only) ---
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime

# --- Web Push (VAPID). Generate once with `make vapid`. ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dani@cosmosthrace.com

# --- CORS (backend allows these origins for browser fetches with credentials) ---
# Comma-separated. Add LAN/ngrok hosts here when testing the PWA from a phone.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Frontend (Vite reads VITE_*) ---
# Empty = use the Vite dev proxy (single origin in the browser, no CORS).
# Empty is the right default in dev because session cookies are SameSite=Lax;
# a cross-origin browser fetch (absolute base) won't send them. Set this only
# when testing from a different host (LAN/ngrok) with HTTPS + Secure cookies.
VITE_API_BASE=
VITE_VAPID_PUBLIC_KEY=
