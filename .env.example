# --- Server ---
APP_ENV=dev                       # dev | prod
LOG_LEVEL=debug                   # debug | info | warn | error
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:5173

# --- Database ---
DATABASE_URL=postgres://journai:journai@localhost:5432/journai?sslmode=disable

# --- Sessions / cookies ---
SESSION_COOKIE_NAME=session
SESSION_TTL_HOURS=720             # 30 days
COOKIE_SECURE=false               # true in prod (HTTPS)

# --- Magic link ---
MAGIC_LINK_TTL_MINUTES=15
MAGIC_LINK_PER_EMAIL_15M=3
MAGIC_LINK_PER_EMAIL_DAY=10
MAGIC_LINK_PER_IP_HOUR=20

# --- Mail (external SMTP provider — Postmark, Resend, Fastmail, your own…) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Journaling Guru <hello@example.com>"

# --- LLM (three tiers, all via OpenRouter) ---
OPENROUTER_API_KEY=
# Streaming chat turns — latency-sensitive, conversational quality matters.
CHAT_MODEL=anthropic/claude-sonnet-4-5
# Async daily / weekly / monthly / yearly summaries.
SUMMARY_MODEL=google/gemma-4-26b-a4b-it
# Async classification + post-session extraction:
# emotion classify, chat coverage tagging, end-of-session field extraction.
CLASSIFY_MODEL=google/gemma-4-26b-a4b-it

# --- Summaries worker ---
# How often the worker scans summary_jobs for due rows (seconds).
SUMMARY_DISPATCH_INTERVAL_SECONDS=60
# After N days of zero entries the scheduler stops auto-arming daily/weekly/
# monthly jobs (yearly continues). Lazy-seed re-engages on the user's next
# journal write.
SUMMARY_INACTIVITY_DAYS=30

# --- OpenAI Realtime (Phase 6b voice — not used in 6a) ---
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime

# --- Chat (Phase 6a) ---
# Model selection lives up top with the other tier defaults. The knobs
# below are session-shape, not model selection.
# Idle sweeper finalizes sessions whose last_activity_at is older than this.
CHAT_IDLE_TIMEOUT_MIN=20
# Hard cap (server-side); the FE shows no timer.
CHAT_HARD_CAP_MIN=30
# Hard turn cap; protects against runaway sessions.
CHAT_MAX_TURNS=50
# How many trailing messages get sent verbatim to the LLM each turn.
CHAT_TRANSCRIPT_KEEP_LAST=30
# Where the in-chat CrisisCard's "Get support" button points.
CHAT_CRISIS_RESOURCES_URL=/resources

# --- Web Push (VAPID). Generate once with `make vapid`. ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dani@cosmosthrace.com

# --- CORS (backend allows these origins for browser fetches with credentials) ---
# Comma-separated. Add LAN/ngrok hosts here when testing the PWA from a phone.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Frontend (Vite reads VITE_*) ---
# Empty = use the Vite dev proxy (single origin in the browser, no CORS).
# Empty is the right default in dev because session cookies are SameSite=Lax;
# a cross-origin browser fetch (absolute base) won't send them. Set this only
# when testing from a different host (LAN/ngrok) with HTTPS + Secure cookies.
VITE_API_BASE=
VITE_VAPID_PUBLIC_KEY=
